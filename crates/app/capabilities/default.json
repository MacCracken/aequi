{
  "identifier": "default",
  "description": "Desktop capability — grants core IPC, filesystem access, and native file dialogs for receipt intake.",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "dialog:allow-open",
    "fs:read-files",
    "fs:write-files",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/aequi-mcp", "sidecar": true }]
    }
  ]
}
