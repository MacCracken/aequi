# Aequi Environment Variables
# Copy this file to .env and adjust for your environment.

# ── Server mode (aequi-server) ──────────────────────────────────────────────

# Path to the SQLite database file
# AEQUI_DB_PATH=./data/ledger.db

# HTTP server port (default: 8060)
# AEQUI_PORT=8060

# API key for Bearer token authentication
# AEQUI_API_KEY=your-secret-api-key

# Log format: "text" (default) or "json" for structured logging
# AEQUI_LOG_FORMAT=text

# CORS allowed origins (comma-separated)
# AEQUI_CORS_ORIGINS=http://localhost:1420,http://localhost:3000

# ── OIDC authentication (optional) ──────────────────────────────────────────

# JSON object: {"issuer_url":"https://...","audience":"..."}
# AEQUI_OIDC_CONFIG=

# ── Email delivery (optional, for invoice sending) ──────────────────────────

# JSON object with SMTP or Resend configuration:
# SMTP: {"backend":"smtp","host":"smtp.example.com","port":587,"username":"...","password":"...","from":"you@example.com"}
# Resend: {"backend":"resend","api_key":"re_...","from":"invoices@yourdomain.com"}
# AEQUI_EMAIL_CONFIG=

# ── Plaid integration (optional) ────────────────────────────────────────────

# JSON object: {"client_id":"...","secret":"...","env":"sandbox"}
# AEQUI_PLAID_CONFIG=

# ── Stripe integration (optional) ───────────────────────────────────────────

# Webhook signing secret for Stripe event verification
# STRIPE_WEBHOOK_SECRET=whsec_...
